generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Assessment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  goal String?
  gender String?
  age Int?
  weight Int?
  weightUnit String?
  mood Int?
  hasSoughtProfessionalHelp Boolean?
  physicalDistress Boolean?
  sleepQuality Int?
  medications String[]
  symptoms String[]
  stressLevel Int?
}

model Journal {
  id        String   @id @default(uuid())
  title     String?
  content   String
  emotion   String   
  createdAt DateTime @default(now())
}

model DailyMood {
  id        String   @id @default(uuid())
  userId    String   // In a real app this would be a relation, but keeping simple for now
  date      DateTime @unique // Ensures one mood per day
  mood      String   // OVERJOYED, HAPPY, NEUTRAL, LOW, OVERWHELMED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StressEntry {
  id        String   @id @default(uuid())
  userId    String
  value     Int
  stressor  String
  impact    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SleepSchedule {
  id           String   @id @default(uuid())
  userId       String
  isEveryday   Boolean  @default(true)
  isToday      Boolean  @default(false)
  sleepTime    String   // e.g. "23:00"
  wakeTime     String   // e.g. "07:00"
  snoozeLength Int      
  autoStats    Boolean  @default(true)
  autoAlarm    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SleepEntry {
  id        String   @id @default(uuid())
  userId    String
  duration  Float
  sleepTime String
  wakeTime  String
  quality   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MindfulSession {
  id              String   @id @default(uuid())
  userId          String
  activity        String
  duration        Float
  plannedDuration Float    @default(0)
  category        String
  timeOfDay       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
