generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  assessments Assessment[]
  journals    Journal[]
  dailyMoods  DailyMood[]
}

model Assessment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  goal String?
  gender String?
  age Int?
  weight Int?
  weightUnit String?
  mood Int?
  hasSoughtProfessionalHelp Boolean?
  physicalDistress Boolean?
  sleepQuality Int?
  medications String[]
  symptoms String[]
  stressLevel Int?
}

model Journal {
  id        String   @id @default(uuid())
  title     String?
  content   String
  emotion   String   
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyMood {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  mood      String   // OVERJOYED, HAPPY, NEUTRAL, LOW, OVERWHELMED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}
