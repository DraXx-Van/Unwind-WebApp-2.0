generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  assessments    Assessment[]
  journals       Journal[]
  dailyMoods     DailyMood[]
  mentors        MentorStudent[]
  messages       Message[]
  aiConversations AiConversation[]
}

model Mentor {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  specialization String   @default("General")
  createdAt      DateTime @default(now())

  codes    MentorCode[]
  students MentorStudent[]
  messages Message[]
}

model MentorCode {
  id        String   @id @default(uuid())
  code      String   @unique
  mentorId  String
  mentor    Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MentorStudent {
  id        String   @id @default(uuid())
  mentorId  String
  mentor    Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([mentorId, userId])
}

model Assessment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  goal String?
  gender String?
  age Int?
  weight Int?
  weightUnit String?
  mood Int?
  hasSoughtProfessionalHelp Boolean?
  physicalDistress Boolean?
  sleepQuality Int?
  medications String[]
  symptoms String[]
  stressLevel Int?
}

model Journal {
  id        String   @id @default(uuid())
  title     String?
  content   String
  emotion   String   
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyMood {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  mood      String   // OVERJOYED, HAPPY, NEUTRAL, LOW, OVERWHELMED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model StressEntry {
  id        String   @id @default(uuid())
  userId    String
  value     Int
  stressor  String
  impact    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SleepSchedule {
  id           String   @id @default(uuid())
  userId       String
  isEveryday   Boolean  @default(true)
  isToday      Boolean  @default(false)
  sleepTime    String   // e.g. "23:00"
  wakeTime     String   // e.g. "07:00"
  snoozeLength Int      
  autoStats    Boolean  @default(true)
  autoAlarm    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SleepEntry {
  id        String   @id @default(uuid())
  userId    String
  duration  Float
  sleepTime String
  wakeTime  String
  quality   Int
  rem       Float?
  core      Float?
  post      Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MindfulSession {
  id              String   @id @default(uuid())
  userId          String
  activity        String
  duration        Float
  plannedDuration Float    @default(0)
  category        String
  timeOfDay       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Message {
  id         String   @id @default(uuid())
  content    String
  senderType String   // "student" or "mentor" or "ai"
  
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  mentorId   String?
  mentor     Mentor?  @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
}

model AiConversation {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String      @default("New Conversation")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AiMessage[]
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // "user" or "model"
  content        String
  createdAt      DateTime       @default(now())
}
